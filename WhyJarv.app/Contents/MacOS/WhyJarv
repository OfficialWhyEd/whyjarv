#!/bin/bash
# WhyJarv — App Launcher
# usa Resources/menu_bar.py per bypassare TCC su ~/Documents

LOG="/tmp/whyjarv_launch.log"
exec > "$LOG" 2>&1
echo "[$(date)] WhyJarv launcher avviato"

BUNDLE_DIR="$(cd "$(dirname "$0")/.." && pwd)"
RESOURCES_DIR="$BUNDLE_DIR/Resources"
PYTHON="$HOME/.whyjarv-venv/bin/python3"

echo "[$(date)] Python: $PYTHON"
echo "[$(date)] Resources: $RESOURCES_DIR"

# Carica .env via osascript (accesso completo a ~/Documents)
ENV_EXPORTS=$(osascript -e 'do shell script "cat ~/Documents/WhyJarv/.env 2>/dev/null | grep -v \"^#\" | grep \"=\""' 2>/dev/null)
while IFS='=' read -r k v; do
    [ -n "$k" ] && export "$k"="$v"
done <<< "$ENV_EXPORTS"

echo "[$(date)] Avvio menu_bar.py da bundle Resources..."
exec "$PYTHON" "$RESOURCES_DIR/menu_bar.py"
